# ============================================
# HOTEL CHATBOT - Environment Variables Template
# Copy this to .env and fill in your values
# ============================================

# ── PostgreSQL ──
POSTGRES_USER=hotel_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=hotel_chatbot
POSTGRES_PORT=5432

# ── n8n ──
N8N_PORT=5678
N8N_ENCRYPTION_KEY=generate_a_random_32_char_string

# ── Google AI (Gemini) ──
# Get your free API key at: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# ── Tunneling & Public URL ──
# Subdomain for exposing local n8n to internet (e.g., https://my-unique-subdomain.loca.lt)
# Choose a unique string to avoid conflict
SUBDOMAIN=ocean-breeze-resort-chatbot

# ── Facebook Messenger (Phase 2) ──
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here
FB_VERIFY_TOKEN=your_custom_webhook_verify_token_here
FB_APP_SECRET=your_facebook_app_secret_here
