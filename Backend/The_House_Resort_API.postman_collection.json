		{
			"name": "3. Search & Booking",
			"item": [
				{
					"name": "Search Available Rooms",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"const today = new Date();",
									"let tomorrow = new Date(today);",
									"tomorrow.setDate(tomorrow.getDate() + 1);",
									"let nextWeek = new Date(today);",
									"nextWeek.setDate(nextWeek.getDate() + 3);",
									"",
									"pm.collectionVariables.set('checkinDate', tomorrow.toISOString().split('T')[0] + 'T14:00:00');",
									"pm.collectionVariables.set('checkoutDate', nextWeek.toISOString().split('T')[0] + 'T12:00:00');"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Search successful', function () {",
									"    pm.response.to.have.status(200);",
									"    const res = pm.response.json();",
									"    pm.expect(res.data).to.be.an('array');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/search/accommodations?checkinDate={{checkinDate}}&checkoutDate={{checkoutDate}}&guestsCount=2&minPrice=0&maxPrice=5000000&type=ROOM",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"search",
								"accommodations"
							],
							"query": [
								{
									"key": "checkinDate",
