								},
								{
									"key": "guestsCount",
									"value": "2"
								},
								{
									"key": "minPrice",
									"value": "0"
								},
								{
									"key": "maxPrice",
									"value": "5000000"
								},
								{
									"key": "type",
									"value": "ROOM"
								},
								{
									"key": "amenityIds",
									"value": "",
									"description": "Optional: danh sách UUID tiện ích, phân tách bằng dấu phẩy",
									"disabled": true
								}
							]
						}
					}
