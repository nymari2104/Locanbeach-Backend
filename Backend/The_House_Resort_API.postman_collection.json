					"name": "Confirm Booking",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Booking confirmed successfully', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"    const res = pm.response.json();",
									"    pm.expect(res.data).to.have.property('bookingId');",
									"    pm.expect(res.data.status).to.eql('PENDING_DEPOSIT');",
									"    pm.collectionVariables.set('bookingId', res.data.bookingId);",
									"    console.log('✅ Booking successfully confirmed! Booking ID: ' + res.data.bookingId);",
